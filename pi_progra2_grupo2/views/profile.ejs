<!DOCTYPE html>
<html lang="es">
<!-- Include Head -->
<%- include('partials/head') %>

<body>
	<!-- Header -->
	<% if (logueado) { %>
		<%- include('partials/headerLogeado') %>

	<% } else { %>
		<%- include('partials/headerNoLogeado') %>

	<% } %>
	<!-- /Header -->

	<!-- Datos del usuario -->
	<section class="info-usuario container products-wrapper">
		<div class="row">
			<div class="img-container offset-3 col-2">
				<img src="/images/users/<%= usuario.imagen %>" alt="foto de perfil" class="foto-perfil">
			</div>
			<div class="data-container col-6">
				<div class="d-flex align-items-center ">
					<h1 class="main-title"><%= usuario.nombre %></h1>
					<a class="btn mt-3 ml-4" href="">SEGUIR</a>
				</div>
				<div>
					<ul class="">
						<li><%= usuario.email %></li>
					</ul>
				</div>
			</div>
		</div>
	</section>
	<!-- /Datos del usuario -->

	<!-- Mis productos -->
	<div class="container products-wrapper">
		<div class="row">
			<div class="col-12">
				<h2 class="products-title">Mis productos</h2>
			</div>

			<% if (productos.length > 0) { %>
				<% for(let i = 0; i < productos.length; i++) { %>
					<div class="col-12 col-sm-6 col-lg-3">
						<section class="product-box">
							<a href="/products/id/<%= productos[i].id %>">
								<figure class="product-box_image">
									<img src="<%= productos[i].img %>" alt="">
								</figure>

								<article class="product-box_data">
									<h2><%= productos[i].nombre %></h2>
									<p><%= productos[i].descripcion %></p>
									<p>Comentarios: <%= productos[i].comentarios.length %></p>
								</article>
							</a>
						</section>
					</div>
				<% } %>
			<% } else { %>
				<p>Este usuario no tiene productos</p>
			<% } %>

		</div>
	</div>
	<!-- /Mis productos -->


	<!-- footer -->
	<%- include('partials/footer') %>

	<!-- /footer -->
</body>	
</html>